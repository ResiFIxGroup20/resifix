# ── Flask ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace-this-with-a-long-random-string

# ── Database ───────────────────────────────────────────────────────────────
# Leave blank to use local SQLite (for local dev)
# On Render: paste the Internal Database URL from your PostgreSQL service
DATABASE_URL=

# ── Email (Gmail App Password) ─────────────────────────────────────────────
MAIL_USERNAME=youraddress@gmail.com
MAIL_PASSWORD="your-app-password-here"
MAIL_FROM_NAME=ResiFix

# ── App base URL ───────────────────────────────────────────────────────────
# Local dev:
APP_BASE_URL=http://127.0.0.1:5000
# On Render (replace with your actual URL):
# APP_BASE_URL=https://resifix.onrender.com

# ── Cloudinary ─────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Groq AI (optional chatbot) ─────────────────────────────────────────────
GROQ_API_KEY=
